rule RERUN_CMAKE
  command = D:\a\_temp\-1212469507\cmake-4.3.1-windows-x86_64\bin\cmake.exe --regenerate-during-build -SD:\a\brlcad_winci\brlcad_winci\brlcad -BD:\a\brlcad_winci\brlcad_winci\brlcad_build
  description = Re-running CMake...
