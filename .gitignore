# External dependency source and build outputs – these are cloned/built
# locally by the CI workflows and must never be committed to the repo.
bext/
bext_output/
bext_build*/
bext_output_debug/

# Test run log files generated by CTest/regress tests
brlcad_build/**/*.log

# CTest state files
brlcad_build/Testing/

# CMake configure artifacts that change on each run
brlcad_build/CMakeFiles/CMakeConfigureLog.yaml
brlcad_build/CMakeFiles/CMakeOutput.log
brlcad_build/CMakeTmp/BRLCAD_BUILD_COUNT
brlcad_build/CMakeTmp/CONFIG_DELTA_START
brlcad_build/include/brlcad/brlcad_ident.h
